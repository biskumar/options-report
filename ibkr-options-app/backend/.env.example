# Copy to .env and adjust. .env is gitignored -- never commit real values.

# 7496 = live TWS, 7497 = paper TWS, 4001 = live IB Gateway, 4002 = paper IB Gateway
IB_HOST=127.0.0.1
IB_PORT=7496
IB_CLIENT_ID=101
IB_ACCOUNT=

# When false, POST /api/orders/submit returns a fake DRY_RUN ack instead of
# calling ib.placeOrder() -- build/test the whole flow safely, then flip to
# true only when you're ready to test against the live account.
ALLOW_ORDERS=false

CORS_ORIGINS=["http://localhost:5175"]

# Optional: alert triggers get pushed to this Telegram bot/chat if both are
# set. Leave blank to disable (alerts still work in-app either way). This is
# a separate config from signal_agent.py's own Telegram setup.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
