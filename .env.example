# Copy to .env at the repo root and fill in real values. .env is gitignored --
# never commit real values. Only needed for scripts/pages that call external
# APIs (currently: the Unusual Whales page/ticker_option_analyzer.py).

# Get a key at https://unusualwhales.com/ (paid subscription required).
# Without this, the IBKR app's "Unusual Whales" page will fail -- every
# other page works fine without it.
UW_API_KEY=
